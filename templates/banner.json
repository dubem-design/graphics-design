{
  "width": 1500,
  "height": 500,
  "fonts": [{ "family": "Inter", "weight": [400, 800] }],
  "root": {
    "type": "container",
    "style": {
      "width": "100%", "height": "100%",
      "display": "flex", "flexDirection": "row",
      "alignItems": "stretch",
      "backgroundColor": "{{bg}}"
    },
    "children": [
      {
        "type": "container",
        "style": { "display": "flex", "flexDirection": "column", "justifyContent": "center", "gap": 16, "padding": 80, "flexGrow": 1 },
        "children": [
          { "type": "text", "text": "{{title}}", "style": { "fontFamily": "Inter", "fontSize": 84, "fontWeight": 800, "color": "{{ink}}", "lineHeight": 1 } },
          { "type": "text", "text": "{{subtitle}}", "style": { "fontFamily": "Inter", "fontSize": 28, "fontWeight": 400, "color": "{{muted}}" } }
        ]
      },
      {
        "type": "container",
        "style": { "display": "flex", "alignItems": "center", "justifyContent": "center", "width": 360, "backgroundColor": "{{accent}}" },
        "children": [
          { "type": "text", "text": "{{badge}}", "style": { "fontFamily": "Inter", "fontSize": 40, "fontWeight": 800, "color": "{{badgeInk}}", "textAlign": "center" } }
        ]
      }
    ]
  }
}
