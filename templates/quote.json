{
  "width": 1080,
  "height": 1080,
  "fonts": [
    { "family": "Fraunces", "weight": [400, 600] },
    { "family": "Inter", "weight": [500] }
  ],
  "root": {
    "type": "container",
    "style": {
      "width": "100%", "height": "100%",
      "display": "flex", "flexDirection": "column",
      "justifyContent": "center", "alignItems": "center",
      "padding": 120, "gap": 48,
      "backgroundColor": "{{bg}}"
    },
    "children": [
      { "type": "text", "text": "“", "style": { "fontFamily": "Fraunces", "fontSize": 160, "fontWeight": 600, "color": "{{accent}}", "lineHeight": 0.5 } },
      { "type": "text", "text": "{{quote}}", "style": { "fontFamily": "Fraunces", "fontSize": 58, "fontWeight": 400, "color": "{{ink}}", "lineHeight": 1.3, "textAlign": "center" } },
      { "type": "text", "text": "{{author}}", "style": { "fontFamily": "Inter", "fontSize": 24, "fontWeight": 500, "color": "{{muted}}", "letterSpacing": 3 } }
    ]
  }
}
