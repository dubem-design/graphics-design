{
  "width": 1080,
  "height": 1350,
  "fonts": [{ "family": "Space Grotesk", "weight": [400, 500, 700] }],
  "root": {
    "type": "container",
    "style": {
      "width": "100%", "height": "100%",
      "display": "flex", "flexDirection": "column",
      "justifyContent": "space-between",
      "padding": 88,
      "backgroundColor": "{{paper}}"
    },
    "children": [
      {
        "type": "container",
        "style": { "display": "flex", "flexDirection": "row", "justifyContent": "space-between" },
        "children": [
          { "type": "text", "text": "{{eyebrow}}", "style": { "fontFamily": "Space Grotesk", "fontSize": 24, "fontWeight": 500, "color": "{{ink}}", "letterSpacing": 1 } },
          { "type": "text", "text": "{{issue}}", "style": { "fontFamily": "Space Grotesk", "fontSize": 24, "fontWeight": 500, "color": "{{accent}}" } }
        ]
      },
      {
        "type": "container",
        "style": { "display": "flex", "flexDirection": "column", "gap": 4 },
        "children": [
          { "type": "text", "text": "{{line1}}", "style": { "fontFamily": "Space Grotesk", "fontSize": 168, "fontWeight": 700, "color": "{{ink}}", "lineHeight": 1 } },
          { "type": "text", "text": "{{line2}}", "style": { "fontFamily": "Space Grotesk", "fontSize": 168, "fontWeight": 700, "color": "{{ink}}", "lineHeight": 1 } },
          { "type": "text", "text": "{{line3}}", "style": { "fontFamily": "Space Grotesk", "fontSize": 168, "fontWeight": 700, "color": "{{accent}}", "lineHeight": 1 } }
        ]
      },
      {
        "type": "container",
        "style": { "display": "flex", "flexDirection": "row", "justifyContent": "space-between", "alignItems": "flex-end" },
        "children": [
          { "type": "text", "text": "{{footer}}", "style": { "fontFamily": "Space Grotesk", "fontSize": 28, "fontWeight": 400, "color": "{{ink}}" } },
          { "type": "text", "text": "{{date}}", "style": { "fontFamily": "Space Grotesk", "fontSize": 28, "fontWeight": 700, "color": "{{ink}}" } }
        ]
      }
    ]
  }
}
